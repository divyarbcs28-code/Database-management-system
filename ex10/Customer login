package ex10;

import javax.swing.*;
import javax.swing.border.*;
import java.awt.*;
import java.sql.*;

/**
 * Screen 1 — Customer Login  (ENTRY POINT — run this)
 *
 * Validations applied:
 *   • Email  — real-time: must match valid email pattern
 *   • Password — real-time: required, min 8 chars with letter + digit
 *   • Both validated again on submit before hitting DB
 */
public class CustomerLogin extends JFrame {

    private JTextField     emailField;
    private JPasswordField passwordField;
    private JLabel         emailHint, passHint, statusLbl;

    public static int loggedInCustomerId = -1;

    public CustomerLogin() {
        UITheme.applyFrame(this, "Shopping System — Login", 460, 430);
        setLayout(new BorderLayout(0, 0));

        // ── Header ──────────────────────────────────────────
        JPanel hdr = UITheme.panel(new BorderLayout());
        hdr.setBorder(new CompoundBorder(
            new MatteBorder(0,0,1,0, UITheme.C_BORDER),
            new EmptyBorder(18, 24, 18, 24)));
        JLabel title = new JLabel("Welcome Back");
        title.setFont(UITheme.F_TITLE); title.setForeground(UITheme.C_TEXT);
        JLabel sub = new JLabel("Sign in to continue");
        sub.setFont(UITheme.F_STATUS); sub.setForeground(UITheme.C_TEXT_MUTED);
        hdr.add(title, BorderLayout.WEST);
        hdr.add(sub,   BorderLayout.EAST);
        add(hdr, BorderLayout.NORTH);

        // ── Form ────────────────────────────────────────────
        JPanel form = UITheme.panel(new GridBagLayout());
        form.setBorder(new EmptyBorder(22, 44, 10, 44));
        GridBagConstraints g = new GridBagConstraints();
        g.fill = GridBagConstraints.HORIZONTAL;
        g.insets = new Insets(2, 6, 0, 6);

        emailField    = UITheme.field();
        passwordField = UITheme.passField();
        emailHint     = hintLabel();
        passHint      = hintLabel();

        // Wire real-time validation
        Validator.wire(emailField,    Validator.RULE_EMAIL,    emailHint);
        Validator.wirePass(passwordField, Validator.RULE_PASSWORD, passHint);

        // Row 0 — Email label
        g.gridx=0; g.gridy=0; g.weightx=0; g.insets=new Insets(8,6,2,6);
        JLabel el = UITheme.mLabel("Email *");
        el.setPreferredSize(new Dimension(90, 24));
        form.add(el, g);
        g.gridx=1; g.weightx=1;
        form.add(emailField, g);

        // Row 1 — Email hint
        g.gridx=1; g.gridy=1; g.weightx=1; g.insets=new Insets(0,6,6,6);
        form.add(emailHint, g);

        // Row 2 — Password label
        g.gridx=0; g.gridy=2; g.weightx=0; g.insets=new Insets(8,6,2,6);
        JLabel pl = UITheme.mLabel("Password *");
        pl.setPreferredSize(new Dimension(90, 24));
        form.add(pl, g);
        g.gridx=1; g.weightx=1;
        form.add(passwordField, g);

        // Row 3 — Password hint
        g.gridx=1; g.gridy=3; g.weightx=1; g.insets=new Insets(0,6,6,6);
        form.add(passHint, g);

        add(form, BorderLayout.CENTER);

        // ── Buttons & status ─────────────────────────────────
        statusLbl = UITheme.statusLabel();

        JButton btnLogin    = UITheme.btn("Login");
        JButton btnRegister = UITheme.btn("Register");
        JButton btnCancel   = UITheme.btn("Cancel");

        btnLogin.addActionListener(e    -> login());
        btnRegister.addActionListener(e -> { dispose(); new CustomerRegistration().setVisible(true); });
        btnCancel.addActionListener(e   -> System.exit(0));

        passwordField.addActionListener(e -> login());  // Enter key triggers login
        emailField.addActionListener(e    -> passwordField.requestFocus());

        JPanel south = UITheme.panel(new BorderLayout());
        south.add(UITheme.btnRow(btnLogin, btnRegister, btnCancel), BorderLayout.CENTER);
        JPanel sRow = UITheme.panel(new FlowLayout(FlowLayout.CENTER));
        sRow.add(statusLbl);
        south.add(sRow, BorderLayout.SOUTH);
        add(south, BorderLayout.SOUTH);
    }

    // ── Submit validation + DB login ──────────────────────────
    private void login() {
        String email    = emailField.getText().trim();
        String password = new String(passwordField.getPassword());

        // 1. Empty check
        if (email.isEmpty()) {
            setStatus("Email is required.", true);
            emailField.requestFocus(); return;
        }
        if (password.isEmpty()) {
            setStatus("Password is required.", true);
            passwordField.requestFocus(); return;
        }

        // 2. Format validation
        if (!Validator.isValidEmail(email)) {
            emailHint.setForeground(Validator.C_ERROR);
            emailHint.setText("Enter a valid email  e.g. user@example.com");
            emailField.setBorder(Validator.borderErr);
            emailField.requestFocus();
            setStatus("Please fix the highlighted fields.", true);
            return;
        }
        if (!Validator.isValidPassword(password)) {
            passHint.setForeground(Validator.C_ERROR);
            passHint.setText("Min 8 chars, at least one letter and one digit");
            passwordField.setBorder(Validator.borderErr);
            passwordField.requestFocus();
            setStatus("Please fix the highlighted fields.", true);
            return;
        }

        // 3. DB authentication
        setStatus("Checking credentials...", false);
        try (Connection conn = DatabaseConnection.getConnection()) {
            PreparedStatement ps = conn.prepareStatement(
                "SELECT customer_id, name FROM Customers1 WHERE email=? AND password=?");
            ps.setString(1, email);
            ps.setString(2, password);
            ResultSet rs = ps.executeQuery();

            if (rs.next()) {
                AppSession.loggedInCustomerId = rs.getInt("customer_id");
                AppSession.loggedInName       = rs.getString("name");
                loggedInCustomerId            = AppSession.loggedInCustomerId;

                setStatus("Login successful! Loading dashboard...", false);
                Timer t = new Timer(800, ev -> { dispose(); new MainDashboard().setVisible(true); });
                t.setRepeats(false); t.start();
            } else {
                setStatus("Invalid email or password. Please try again.", true);
                emailField.setBorder(Validator.borderErr);
                passwordField.setBorder(Validator.borderErr);
            }
        } catch (SQLException ex) {
            setStatus("Database error: " + ex.getMessage(), true);
        }
    }

    private void setStatus(String msg, boolean isError) {
        statusLbl.setText(msg);
        statusLbl.setForeground(isError ? new Color(180,30,30) : new Color(20,130,60));
    }

    private JLabel hintLabel() {
        JLabel l = new JLabel(" ");
        l.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        l.setForeground(Validator.C_ERROR);
        return l;
    }

    // ── ENTRY POINT ──────────────────────────────────────────
    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> new CustomerLogin().setVisible(true));
    }
}
