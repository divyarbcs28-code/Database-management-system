package ex10;

import javax.swing.*;
import javax.swing.border.*;
import javax.swing.table.*;
import java.awt.*;
import java.sql.*;

/**
 * Screen 3 — Product Display
 * Embedded inside MainDashboard (not a standalone JFrame anymore).
 */
public class ProductDisplay {

    private final MainDashboard dashboard;
    private DefaultTableModel   model;
    private JTable              table;
    private JLabel              statusLbl;

    public ProductDisplay(MainDashboard dashboard) {
        this.dashboard = dashboard;
    }

    /** Returns the panel to embed in the CardLayout */
    public JPanel buildPanel() {
        JPanel root = UITheme.bgPanel(new BorderLayout(0, 0));
        root.add(UITheme.sectionHeader("🏪  Product Catalogue",
                 ""), BorderLayout.NORTH);

        // Table
        String[] cols = {"Product ID", "Name", "Category", "Price (Rs)", "Stock"};
        model = new DefaultTableModel(cols, 0) {
            public boolean isCellEditable(int r, int c) { return false; }
        };
        table = UITheme.styledTable(model);

        JPanel center = UITheme.panel(new BorderLayout());
        center.setBorder(new EmptyBorder(12, 16, 0, 16));
        center.add(UITheme.scrl(table), BorderLayout.CENTER);
        root.add(center, BorderLayout.CENTER);

        // Buttons
        statusLbl = UITheme.statusLabel();

        JButton btnLoad  = UITheme.btn("Load Products");
        JButton btnCart  = UITheme.btn("Add products");
      //  JButton btnClear = UITheme.btn("Clear Selection");

        btnLoad.addActionListener(e  -> loadProducts());
        btnCart.addActionListener(e  -> new AdminDashboard().showDashboard());
   //     btnClear.addActionListener(e -> table.clearSelection());

        JPanel south = UITheme.panel(new BorderLayout());
        south.add(UITheme.btnRow(btnLoad,btnCart), BorderLayout.CENTER);
        JPanel sRow = UITheme.panel(new FlowLayout(FlowLayout.CENTER));
        sRow.add(statusLbl);
        south.add(sRow, BorderLayout.SOUTH);
        root.add(south, BorderLayout.SOUTH);

        // Load immediately
        SwingUtilities.invokeLater(this::loadProducts);
        return root;
    }

    private void loadProducts() {
        model.setRowCount(0);
        try (Connection conn = DatabaseConnection.getConnection();
             Statement stmt = conn.createStatement();
             ResultSet rs = stmt.executeQuery(
                "SELECT product_id,product_name,category,price,stock_quantity FROM Products1")) {
            int count = 0;
            while (rs.next()) {
                model.addRow(new Object[]{
                    rs.getInt("product_id"), rs.getString("product_name"),
                    rs.getString("category"), rs.getDouble("price"),
                    rs.getInt("stock_quantity")});
                count++;
            }
            statusLbl.setText("Loaded " + count + " products.");
        } catch (SQLException ex) {
            statusLbl.setText("Error loading products: " + ex.getMessage());
        }
    }

    private void addToCart() {
        int row = table.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(dashboard, "Please select a product first.");
            return;
        }
        int productId = (int) model.getValueAt(row, 0);
        String name   = (String) model.getValueAt(row, 1);

        String input = JOptionPane.showInputDialog(dashboard,
            "Enter quantity for: " + name, "1");
        if (input == null) return;

        try {
            int qty = Integer.parseInt(input.trim());
            if (qty <= 0) { JOptionPane.showMessageDialog(dashboard,"Quantity must be > 0."); return; }

            if (ShoppingCart.addProductToCart(AppSession.loggedInCustomerId, productId, qty)) {
                statusLbl.setText("Added " + qty + "x " + name + " to cart.");
                JOptionPane.showMessageDialog(dashboard, qty + "x \"" + name + "\" added to cart!");
            } else {
                JOptionPane.showMessageDialog(dashboard, "Failed to add to cart.");
            }
        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(dashboard, "Please enter a valid number.");
        }
    }
}
